      "id": "pattern_001",
      "name": "Test-Time Compute Scaling (Reasoning Models)",
      "category": "reasoning",
      "description": "Paradigm shift from training-time scaling to allocating additional computation during inference through extended chain-of-thought generation",
      "first_emergence": "2024-09",
      "maturity": "emerging",
      "key_innovations": [
        "Process Reward Models (PRM) for step-by-step verification",
        "Group Relative Policy Optimization (GRPO) for RL training",
        "Inference-time scaling laws showing performance ∝ compute budget",
        "Self-consistency and search over reasoning paths"
      ],
